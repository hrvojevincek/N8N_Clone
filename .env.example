# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/n8n_clone
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars
ENCRYPT_KEY=another-random-secret-for-credentials

# App URL (used for webhook URLs in the UI)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inngest — local dev (required for workflow execution + realtime node status)
INNGEST_DEV=1

# GitHub OAuth (optional — email/password works without these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Polar billing — sandbox (optional for local dev without subscriptions)
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
